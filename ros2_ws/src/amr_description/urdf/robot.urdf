  </joint>

  <joint name="left_wheel_jt" type="continuous">
    <origin xyz="0.00024987 0.1735 0.025002" rpy="0 0 0" />
    <parent link="base_link" />
    <child link="left_wheel" />
    <axis xyz="0 1 0" />
    <!-- <axis xyz="0.0025766 1 0" /> -->
